# Alubee WhatsApp bot — non-secret settings (edit this file; do not put API keys here).
# Secrets: INTERAKT_API_KEY, WHATSAPP_CLOUD_API_TOKEN → Cloud Run or Interakt/.env only.
#
# After changes: redeploy alubee-interakt-od-bot (bot_config.env is in the image).

# --- Firestore / Storage ---
FIREBASE_PROJECT_ID=whatsapp-approval-system
FIREBASE_STORAGE_BUCKET=whatsapp-approval-system.firebasestorage.app
WHATSAPP_GRAPH_API_VERSION=v21.0

# --- Approvers (JMD → MD) ---
JMD_I_WHATSAPP_NUMBER=whatsapp:+919751100705
JMD_II_WHATSAPP_NUMBER=whatsapp:+919787466677
MD_WHATSAPP_NUMBER=whatsapp:+919362310181
WHATSAPP_SESSION_HOURS=24

# --- Visitor routing ---
VISITOR_ROUTE_BY_UNIT=false


# --- JMD/MD approval templates (OD, Leave, Visitor) ---
APPROVAL_TEMPLATE_LANGUAGE_CODE=en


# --- WhatsApp Flow forms (menu) ---
OD_FLOW_TEMPLATE_NAME=od_request_v02
OD_FLOW_TEMPLATE_LANGUAGE_CODE=en
OD_FLOW_TEMPLATE_BODY_FIELDS=name
OD_APPROVAL_TEMPLATE_NAME=od_approval_message_v01
OD_APPROVAL_TEMPLATE_BODY_FIELDS=employee,department,date,visiting_to,purpose,time_required

#-----Visitor System----
VISITOR_FLOW_TEMPLATE_NAME=visitor_request_v02
VISITOR_FLOW_TEMPLATE_LANGUAGE_CODE=en
VISITOR_FLOW_TEMPLATE_BODY_FIELDS=name
VISITOR_APPROVAL_TEMPLATE_NAME=visitor_approval_v01
VISITOR_APPROVAL_TEMPLATE_BODY_FIELDS=employee,department,visitor_name,visitor_type,visiting_to,purpose,coming_on,coming_from,people_count,mobile

VISITOR_OTP_TEMPLATE_NAME=visitor_pass_code
VISITOR_OTP_TEMPLATE_LANGUAGE_CODE=en
VISITOR_OTP_TEMPLATE_BODY_FIELDS=otp
VISITOR_OTP_TEMPLATE_AUTH_BUTTON=true

#-----Leave System----

LEAVE_FLOW_TEMPLATE_NAME=leave_request_v02
LEAVE_FLOW_TEMPLATE_LANGUAGE_CODE=en
LEAVE_FLOW_TEMPLATE_BODY_FIELDS=name
LEAVE_APPROVAL_TEMPLATE_NAME=leave_approval_v01
LEAVE_APPROVAL_TEMPLATE_BODY_FIELDS=employee,department,days,from_date,to_date,reason,leaves_current_month,leaves_last_month

# --- IT ticket notify ---
IT_FLOW_TEMPLATE_NAME=it_request_v02
IT_FLOW_TEMPLATE_LANGUAGE_CODE=en
IT_FLOW_TEMPLATE_BODY_FIELDS=name

IT_ENGINEER_ASSIGN_TEMPLATE_NAME=it_ticket_notification
IT_ENGINEER_ASSIGN_BODY_TEMPLATE_NAME=it_message_without_photo
IT_ENGINEER_ASSIGN_TEMPLATE_LANGUAGE_CODE=en
IT_ENGINEER_ASSIGN_TEMPLATE_BODY_FIELDS=employee,department,category,machine,issue,description,priority,requested_at

# --- Vehicle request ---
VEHICLE_REQUEST_FLOW_TEMPLATE_NAME=vehicle_request_v02
VEHICLE_REQUEST_FLOW_TEMPLATE_LANGUAGE_CODE=en
VEHICLE_REQUEST_FLOW_TEMPLATE_BODY_FIELDS=name
VEHICLE_INTERNAL_ASSIGN_DEPARTMENT=LOGISTICS

LOGISTICS_MANAGER_WHATSAPP_NUMBER=whatsapp:+919597321173
VEHICLE_REQUEST_APPROVAL_TEMPLATE_NAME=vehicle_assigner_message
VEHICLE_REQUEST_APPROVAL_TEMPLATE_LANGUAGE_CODE=en
VEHICLE_REQUEST_APPROVAL_TEMPLATE_BODY_FIELDS=requester,department,from,request_type,category,destination,vehicle_type,hire_vehicle_type,load_capacity,distance,required_at
VEHICLE_ASSIGNEE_NOTIFY_TEMPLATE_NAME=vehicle_assignee_message
